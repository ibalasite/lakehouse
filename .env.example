# ── MinIO ──────────────────────────────────
# Copy this file to .env and fill in real values before starting the stack.
# Never commit .env to version control.

MINIO_ROOT_USER=change_me
MINIO_ROOT_PASSWORD=change_me
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=lakehouse

# ── Apache Polaris ──────────────────────────
POLARIS_PORT=8181
POLARIS_MGMT_PORT=8182
POLARIS_REALM=POLARIS
POLARIS_CLIENT_ID=change_me
POLARIS_CLIENT_SECRET=change_me
POLARIS_CATALOG=lakehouse

# ── Trino ───────────────────────────────────
TRINO_PORT=8080

# ── MySQL ───────────────────────────────────
MYSQL_ROOT_PASSWORD=change_me
MYSQL_DATABASE=lakehouse_cache
MYSQL_USER=lakehouse
MYSQL_PASSWORD=change_me
MYSQL_PORT=3306

# ── PostgreSQL (Airflow backend) ────────────
POSTGRES_USER=airflow
POSTGRES_PASSWORD=change_me
POSTGRES_DB=airflow
POSTGRES_PORT=5432

# ── Airflow ─────────────────────────────────
AIRFLOW_PORT=8888
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=change_me
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=change_me
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:change_me@postgres:5432/airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=False

# ── Metabase ─────────────────────────────────
METABASE_PORT=3000
METABASE_URL=http://localhost:3000
METABASE_ADMIN_EMAIL=admin@local.com
METABASE_ADMIN_PASSWORD=change_me
